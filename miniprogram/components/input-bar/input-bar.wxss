/* Input Bar */
.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  border-top: 1rpx solid var(--border);
  gap: 16rpx;
  z-index: 998;
}

.input-wrapper {
  flex: 1;
  background: #F3F4F6;
  border-radius: var(--radius-pill);
  padding: 12rpx 24rpx;
}

.chat-input {
  font-size: 28rpx;
  color: var(--text-primary);
}

.placeholder {
  color: var(--text-muted);
  font-size: 26rpx;
}

.send-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--text-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.send-btn.active {
  background: var(--primary);
}

.send-icon {
  width: 36rpx;
  height: 36rpx;
}
